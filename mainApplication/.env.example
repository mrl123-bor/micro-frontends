# 复制为 .env 或按环境写入 .env.development / .env.production / .env.staging

# 展示类
VITE_APP_TITLE=后台管理系统
VITE_APP_ENV=development

# 接口前缀
VITE_APP_BASE_API=/api
VITE_API_BASE=/api

# 可选：子路径部署（需以 / 结尾）
# VITE_PUBLIC_PATH=/admin/

# 标签模板设计器 qiankun 子应用入口（必填；未配置时设计页仅显示提示，不加载主应用内设计器）
# 开发：先启动子应用 npm run dev（端口见 subapps/print-design-micro/vite.config.ts）
# VITE_PRINT_DESIGN_ENTRY=http://127.0.0.1:5174/

# 内容 / 示例页 qiankun 子应用（可选；未配置时主应用显示壳内提示）
# VITE_CONTENT_MICRO_ENTRY=http://127.0.0.1:5175/
# VITE_EXAMPLES_MICRO_ENTRY=http://127.0.0.1:5176/

# 运行模式：integration（默认）= 真实后端；demo = 纯前端演示（占位接口，见 README）
# VITE_APP_RUNTIME=demo

# 可选开关
VITE_DEMO_SWITCHER=false
VITE_I18N_SWITCHER=false
# 登录页：账号密码 / 手机号表单切换（true=显示手机号入口；未对接后端时手机号登录仅提示）
# VITE_LOGIN_MOBILE=true
VITE_ANTI_CRAWLER=false
VITE_ANTI_CRAWLER_DEVTOOLS=false

VITE_APP_ENV=production
# 与主应用同源：https://www.lghdev.com/admin + https://www.lghdev.com/examples-micro/
# Nginx 需将 /examples-micro/ 指到本包 dist；构建产物内静态资源前缀与此一致
VITE_PUBLIC_PATH=/examples-micro/
# 与 admin 的 VITE_PUBLIC_PATH 一致，供 qiankun 下 createWebHistory(base) 解析 /admin/demo/...
VITE_QIANKUN_HOST_BASE=/admin/
VITE_APP_BASE_API=/api
VITE_API_BASE=/api
